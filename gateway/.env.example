# TTS Gateway Environment Configuration
# Copy this file to .env and update the values

# Gateway Settings
TTS_GATEWAY_HOST=0.0.0.0
TTS_GATEWAY_PORT=8000
TTS_GATEWAY_RELOAD=false
TTS_LOG_LEVEL=INFO

# Output Directories
TTS_OUTPUT_DIR=./gateway_output
TTS_UPLOAD_DIR=./gateway_output/uploads

# Provider Config File
TTS_PROVIDERS_CONFIG=./config/providers.yaml

# CORS Origins (comma-separated)
TTS_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# Provider API Keys
# =============================================================================

# Cartesia (comma-separated for multiple keys)
CARTESIA_API_KEYS=your-cartesia-api-key-1,your-cartesia-api-key-2

# ElevenLabs (comma-separated for rotation)
ELEVENLABS_API_KEYS=your-elevenlabs-api-key-1,your-elevenlabs-api-key-2

# Gemini / Google
GEMINI_API_KEY=your-gemini-api-key
GEMINI_VERTEX_PROJECT=your-gcp-project-id
GEMINI_VERTEX_LOCATION=us-central1

# MiniMax
MINIMAX_API_KEY=your-minimax-api-key

# VNPost
VNPOST_API_KEY=your-vnpost-api-key

# Xiaomi (OmniVoice)
XIAOMI_CLONE_API_BASE=https://rxcvyunvtyun--k2-fsa--omnivoice-serve.modal.run
XIAOMI_CLONE_ENDPOINT=/run/k2-fsa/OmniVoice/clone
XIAOMI_STT_API_BASE=http://0.0.0.0:13081/asr/v1/
XIAOMI_STT_ENDPOINT=file
